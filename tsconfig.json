{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    // The library ships .d.ts files, generated by `npm run build`. Enabling
    // `declaration` while keeping `noEmit`, enables declaration-emit
    // diagnostics without actually emitting any files. This ensures that `npm
    // run typecheck` catches errors that would otherwise only surface at `npm
    // run build`.
    "declaration": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "noImplicitReturns": true
  },
  "include": ["src", "examples", ".storybook"]
}
