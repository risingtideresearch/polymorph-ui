{
  "name": "polymorph-ui",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "src/main.ts",
  "types": "src/main.ts",
  "exports": {
    ".": {
      "types": "./src/main.ts",
      "import": "./src/main.ts"
    },
    "./reset.css": "./src/reset.css",
    "./base.css": "./src/base.css"
  },
  "scripts": {
    "test": "vitest run",
    "test-watch": "vitest",
    "dev": "vite",
    "example": "vite --mode",
    "watch": "watchexec -w . vite build --mode debug",
    "css-modules": "vite-css-modules",
    "build": "vite-css-modules && tsc && vite build",
    "build:debug": "vite build --mode debug",
    "preview": "vite preview",
    "lint": "eslint --max-warnings 0 .",
    "typecheck": "vite-css-modules && tsc -b",
    "format": "prettier --ignore-path .prettierignore --write .",
    "formatcheck": "prettier --ignore-path .prettierignore --check .",
    "check": "npm run typecheck; l=$?; npm run lint; r=$?; npm run formatcheck && exit $((l || r))",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@storybook/react-vite": "^10.4.2",
    "@types/eslint__js": "^8.42.3",
    "@types/node": "^25.0.6",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.13",
    "eslint-plugin-storybook": "^10.4.2",
    "lightningcss": "^1.32.0",
    "prettier": "^3.8.3",
    "storybook": "^10.4.2",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.9",
    "vite-css-modules": "^1.9.2",
    "vite-plugin-dts": "^4.5.3",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-dropdown-menu": "^2.1.7",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-popover": "^1.1.13",
    "@radix-ui/react-select": "^2.2.6",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@types/three": ">=0.182.0",
    "@use-gesture/react": "^10.3.1",
    "browser-fs-access": "^0.35.0",
    "react-resizable-panels": "^4.5.6",
    "three": ">=0.182.0",
    "uuid": "^11.0.3"
  }
}
